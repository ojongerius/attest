{
	"name": "attest",
	"version": "0.1.0",
	"description": "Cryptographically signed audit trail for AI agent actions",
	"license": "Apache-2.0",
	"author": "Otto Jongerius",
	"type": "module",
	"bin": {
		"attest": "dist/cli/main.js",
		"attest-proxy": "dist/proxy/main.js"
	},
	"scripts": {
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"check": "pnpm run typecheck && pnpm run lint",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"lefthook"
		]
	},
	"packageManager": "pnpm@10.33.0",
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@types/node": "^25.5.0",
		"lefthook": "^2.1.4",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	}
}
